---

import "../styles/aircss.css";
import "../styles/global.css";
import Instagram from "@/components/instagram.astro";
import Twitter from "@/components/twitter.astro";
import Linkedin from "@/components/linkedin.astro";
import Facebook from "@/components/facebook.astro";
---
<style>
    .footer {
    background: #111827;
    color: #fff;
    padding: 60px 20px 20px;
}

.footer-container {
    display: flex;
    flex-wrap: wrap;
    gap: 40px;
    justify-content: space-between;
}

.footer-column {
    flex: 1;
    min-width: 250px;
}

.footer-column h3 {
    margin-bottom: 20px;
}

.footer-column p {
    line-height: 1.7;
    color: #d1d5db;
}

.footer-column ul {
    list-style: none;
    padding: 0;
}

.footer-column li {
    margin-bottom: 10px;
}

.footer-column a {
    color: #d1d5db;
    text-decoration: none;
    transition: .3s;
}

.footer-column a:hover {
    color: #fff;
}

.newsletter {
    display: flex;
    margin: 20px 0;
    align-items: center;
}

.newsletter input {
    flex: 1;
    padding: 17px;
    height: 46px;
    border: none;
    outline: none;
    border-radius: 0px;
}

.newsletter button {
    padding: 12px 18px;
    border: none;
    background: #2563eb;
    color: white;
    cursor: pointer;
    border-radius: 0 5px 5px 0;
}

.social-icons {
    display: flex;
    gap: 15px;
}

.social-icons a {
    width: 40px;
    height: 40px;
   
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: 50%;
    font-size: 18px;
}

.footer-bottom {
    border-top: 1px solid #374151;
    margin-top: 40px;
    padding-top: 20px;
    text-align: center;
    color: #9ca3af;
}

.logo {
           width: 285px;
           padding-top: 29px;
    }
</style>


<footer class="footer">
    <div class="footer-container">

        <!-- Columna 1 -->
        <div class="footer-column">
            <h3>Graphenix Studio</h3>
            <p>
                Creamos soluciones de diseño web, desarrollo y marketing
                para impulsar tu presencia digital.
            </p>
            <img src="/src/assets/Group 4.png" class="logo" />
        </div>

        <!-- Columna 2 -->
        <div class="footer-column">
            <h3>Enlaces</h3>
            <ul>
                <li><a href="#">Inicio</a></li>
                <li><a href="#">Servicios</a></li>
                <li><a href="#">Portafolio</a></li>
                <li><a href="#">Contacto</a></li>
            </ul>
        </div>

        <!-- Columna 3 -->
        <div class="footer-column">
            <h3>Suscríbete</h3>
            <p>Recibe noticias y consejos directamente en tu correo.</p>

            <form class="newsletter">
                <input
                    type="email"
                    placeholder="Tu correo electrónico"
                    required
                >
                <button type="submit">Suscribirse</button>
            </form>

            <div class="social-icons">
                <a href="#"><Instagram color="#4ade56"/></a>
                <a href="#"><Twitter color="#4ade56"/></a>
                <a href="#"><Linkedin color="#4ade56"/></a>
                <a href="#"><Facebook color="#4ade56"/></a>
            </div>
        </div>

    </div>

    <div class="footer-bottom">
        <p>&copy; 2026 Graphenix Studio. Todos los derechos reservados.</p>
    </div>
</footer>